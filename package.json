{
  "name": "Auth-Server_Backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "nodemon ./dist/bin/auth-server",
    "tsc": "npx tsc -w",
    "build:assets": "cpx \"public/**/*\" dist/public && cpx \"src/views/**/*\" dist/views",
    "watch:assets": "concurrently \"cpx \"public/**/*\" dist/public --watch\" \"cpx \"src/views/**/*\" dist/views --watch\"",
    "tsc-start": "npm run build:assets && concurrently \"npm run watch:assets\" \"npx tsc-watch --onSuccess \\\"node ./dist/bin/www\\\"\""
  },
  "dependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/nodemailer": "^6.4.17",
    "bcrypt": "^5.1.1",
    "cookie": "^1.0.2",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "debug": "~2.6.9",
    "dotenv": "^17.4.2",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.12.0",
    "morgan": "~1.9.1",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "pug": "2.0.0-beta11",
    "redis": "^4.7.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "concurrently": "^10.0.3",
    "cpx2": "^9.0.0",
    "nodemon": "^3.1.7",
    "typescript": "^5.7.2"
  }
}
